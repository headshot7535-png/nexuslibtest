        local function shortSrv()
            local j = game.JobId
            return j ~= "" and j:sub(1,5) or "local"
        end

        local function doSend(raw)
            local trimmed = type(raw) == "string" and raw:match("^%s*(.-)%s*$") or ""
            if trimmed == "" then return end
            local imageUrl = nil
            local bodyText = trimmed
            local firstLine, rest = trimmed:match("^([^\r\n]+)[\r\n]+(.+)$")
            if firstLine and rest and isImageLikeUrl(firstLine) then
                imageUrl = firstLine:match("^%s*(.-)%s*$")
                bodyText = rest:match("^%s*(.-)%s*$") or ""
                if bodyText == "" then bodyText = "📷" end
            elseif isImageLikeUrl(trimmed) then
                imageUrl = trimmed
                bodyText = "📷"
            end
            local payloadTbl = {
                user   = "Anonymous",
                server = shortSrv(),
                text   = bodyText,
                time   = os.time(),
            }
            if imageUrl then payloadTbl.imageUrl = imageUrl end
            local payload = HS:JSONEncode(payloadTbl)
            local ok, res = pcall(httpRequest, {
                Url     = firebaseUrl..".json",
                Method  = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = payload,
            })
            if not ok or not res then
                addLine(nil, "❌ Send failed: "..tostring(res), nil, true)
            elseif res.StatusCode and res.StatusCode >= 400 then
                addLine(nil, "❌ HTTP "..res.StatusCode, nil, true)
            end
        end

        PasteBtn.MouseButton1Click:Connect(function()
            local c = getClipboardText()
            if not c then
                addLine(nil, "Clipboard empty or executor has no getclipboard()", nil, true)
                return
            end
            if isImageLikeUrl(c) then
                ChatInput.Text = c
                return
            end
            local cur = ChatInput.Text
            if cur == "" or cur:match("^%s*$") then
                ChatInput.Text = c
            elseif not cur:find(c, 1, true) then
                ChatInput.Text = cur .. (cur:match("%s$") and "" or " ") .. c
            end
        end)

        UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.KeyCode ~= Enum.KeyCode.V then return end
            if not (UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)) then return end
            if not ChatInput:IsFocused() then return end
            task.defer(function()
                local c = getClipboardText()
                if not c or not isImageLikeUrl(c) then return end
                local cur = ChatInput.Text
                if cur == "" or cur:match("^%s*$") then
                    ChatInput.Text = c
                elseif not cur:find(c, 1, true) then
                    ChatInput.Text = cur .. (cur:match("%s$") and "" or " ") .. c
                end
            end)
        end)

        SendBtn.MouseButton1Click:Connect(function()
            local txt = ChatInput.Text:match("^%s*(.-)%s*$")
            if txt == "" then return end
            doSend(ChatInput.Text); ChatInput.Text = ""
        end)
        ChatInput.FocusLost:Connect(function(enter)
            if enter then
                local txt = ChatInput.Text:match("^%s*(.-)%s*$")
                if txt ~= "" then doSend(ChatInput.Text); ChatInput.Text = "" end
            end
        end)

        -- poll (cap seen to 500 keys to avoid unbounded growth)
        local SEEN_CAP = 500
        local seenKeys = {}
        local seenOrder = {}

        local function pruneSeen()
            while #seenOrder > SEEN_CAP do
                local k = table.remove(seenOrder, 1)
                seenKeys[k] = nil
            end
        end

        task.spawn(function()
            _G.NexusLib_ChatGen = (_G.NexusLib_ChatGen or 0) + 1
            local myGen = _G.NexusLib_ChatGen

            local function fetch()
                local ok, res = pcall(httpRequest, {
                    Url     = firebaseUrl..".json",
                    Method  = "GET",
                    Headers = { ["Accept"] = "application/json" },
                })
                if not ok or not res or not res.Body or res.Body == "" or res.Body == "null" then return false end
                local ok2, data = pcall(HS.JSONDecode, HS, res.Body)
                if not ok2 or type(data) ~= "table" then return false end
                local msgs = {}
                for key, v in pairs(data) do
                    if type(v) == "table" and v.time and not seenKeys[key] then
                        local iu = v.imageUrl
                        if type(iu) ~= "string" or iu == "" then
                            local tx = tostring(v.text or "")
                            if isImageLikeUrl(tx) then iu = tx:match("^%s*(.-)%s*$") end
                        end
                        table.insert(msgs, {
                            key = key, user = v.user, server = v.server, text = v.text, time = v.time,
                            imageUrl = (type(iu) == "string" and iu ~= "") and iu or nil,
                        })
                    end
                end
                table.sort(msgs, function(a,b) return a.time < b.time end)
                for i = 1, #msgs do
                    local m = msgs[i]
                    seenKeys[m.key] = true
                    table.insert(seenOrder, m.key)
                    addLine(m.user, m.text, m.server, false, m.imageUrl)
                end
                pruneSeen()
                return #msgs > 0
            end

            fetch()
            OnlineLbl.Text = "🟢 Live"

            while true do
                if _G.NexusLib_ChatGen ~= myGen then break end
                task.wait(3)
                if _G.NexusLib_ChatGen ~= myGen then break end
                fetch()
            end
        end)
    end

