    -- ============================================================
    --  BUILT-IN: Player Tab (optimized noclip + god mode throttle)
    -- ============================================================
    function Win:PlayerTab()
        local T = self:Tab("👤","Player")
        local runGen = newGen()

        T:Section("Movement")

        local speedRef = { val = 16 }
        T:Slider("Walk Speed","Default 16 · Max 300",{min=0,max=300,default=16}, function(v)
            speedRef.val = v
            local h = getHuman()
            if h then h.WalkSpeed = v end
        end)

        T:Toggle("🚀 Infinite Jump","Jump again while airborne", false, function(on)
            local myGen = newGen(); runGen = myGen
            if on then
                local conn; conn = UserInputService.JumpRequest:Connect(function()
                    if runGen ~= myGen then conn:Disconnect(); return end
                    local h = getHuman()
                    if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
                end)
            end
        end)

        Players.LocalPlayer.CharacterAdded:Connect(function(char)
            local h = char:WaitForChild("Humanoid", 5)
            if h then h.WalkSpeed = speedRef.val end
        end)

        T:Section("Utility")

        T:Toggle("⏱️ Anti AFK","Prevents auto-kick every 55s", false, function(on)
            local myGen = newGen(); runGen = myGen
            if on then
                task.spawn(function()
                    local VU = game:GetService("VirtualUser")
                    while true do
                        if runGen ~= myGen then break end
                        task.wait(55)
                        if runGen ~= myGen then break end
                        VU:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                        task.wait(0.1)
                        VU:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                    end
                end)
            end
        end)

        -- Noclip: cache BaseParts (no per-frame GetDescendants)
        local noclipParts = {}
        local noclipConns = {}
        local function clearNoclipConns()
            for i = 1, #noclipConns do pcall(function() noclipConns[i]:Disconnect() end) end
            noclipConns = {}
        end
        local function rebuildNoclipParts(char)
            table.clear(noclipParts)
            clearNoclipConns()
            if not char then return end
            for _, d in ipairs(char:GetDescendants()) do
                if d:IsA("BasePart") then noclipParts[#noclipParts+1] = d end
            end
            noclipConns[#noclipConns+1] = char.DescendantAdded:Connect(function(d)
                if d:IsA("BasePart") then noclipParts[#noclipParts+1] = d end
            end)
            noclipConns[#noclipConns+1] = char.DescendantRemoving:Connect(function(d)
                if not d:IsA("BasePart") then return end
                for i = #noclipParts, 1, -1 do
                    if noclipParts[i] == d then table.remove(noclipParts, i) end
                end
            end)
        end
        rebuildNoclipParts(getChar())
        LP.CharacterAdded:Connect(function(c) rebuildNoclipParts(c) end)

        T:Toggle("👻 No Clip","Walk through walls", false, function(on)
            local myGen = newGen(); runGen = myGen
            if on then
                local lastPrune = 0
                local conn; conn = RunService.Stepped:Connect(function()
                    if runGen ~= myGen then conn:Disconnect(); return end
                    local now = os.clock()
                    if now - lastPrune > 5 then
                        lastPrune = now
                        for i = #noclipParts, 1, -1 do
                            local p = noclipParts[i]
                            if not (p and p.Parent) then table.remove(noclipParts, i) end
                        end
                    end
                    for i = 1, #noclipParts do
                        local p = noclipParts[i]
                        if p and p.Parent then p.CanCollide = false end
                    end
                end)
            end
        end)

        -- God mode: throttle to 0.5s
        local lastGod = 0
        T:Toggle("🛡️ God Mode","Lock health to max", false, function(on)
            local myGen = newGen(); runGen = myGen
            if on then
                task.spawn(function()
                    while true do
                        if runGen ~= myGen then break end
                        local now = os.clock()
                        if now - lastGod >= 0.5 then
                            lastGod = now
                            local h = getHuman()
                            if h then h.Health = h.MaxHealth end
                        end
                        task.wait(0.1)
                    end
                end)
            end
        end)

        T:Section("Actions")

        T:Button("🔄","Respawn","Reset character", C.purple, function()
            local h = getHuman()
            if h then h.Health = 0 end
        end)

        T:Button("📋","Print Position","Prints XYZ to output", C.accent, function()
            local r = getRoot()
            if r then
                local p = r.Position
                print(string.format("[NexusLib] Position: X=%.1f Y=%.1f Z=%.1f", p.X, p.Y, p.Z))
            end
        end)

        return T
    end

    return Win
