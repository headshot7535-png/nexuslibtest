        -- Dropdown: single-select by default, set multi=true for multi-select
        -- Single: Dropdown(label, desc, options, defaultIndex, cb)
        -- Multi : Dropdown(label, desc, options, defaultIndicesTable, cb, true)
        function T:Dropdown(label, desc, options, defaultIndex, cb, multi)
            order = order + 1
            local cardOrder = order
            local opts = options or {}
            local list = {}
            for i, v in ipairs(opts) do
                if type(v) == "table" then list[i] = { text = v.text or v[1], value = v.value ~= nil and v.value or v[2] or v } else list[i] = { text = tostring(v), value = v } end
            end
            local isMulti = (multi == true) or (type(defaultIndex) == "table")
            local curIdx = math.clamp((type(defaultIndex) == "number" and defaultIndex or 1), 1, math.max(1, #list))
            local cur = list[curIdx]
            local selected = {}
            if isMulti then
                for _, idx in ipairs(type(defaultIndex) == "table" and defaultIndex or {}) do
                    if idx >= 1 and idx <= #list then selected[idx] = true end
                end
            end

            local Card = Instance.new("Frame", page)
            Card.Size = UDim2.new(1,-10,0,52); Card.BackgroundColor3 = C.card; Card.BorderSizePixel = 0; Card.LayoutOrder = cardOrder
            Instance.new("UICorner", Card).CornerRadius = UDim.new(0,10)
            Instance.new("UIStroke", Card).Color = C.border

            local nL = Instance.new("TextLabel", Card)
            nL.Text = label; nL.Size = UDim2.new(1,-80,0,18); nL.Position = UDim2.new(0,14,0,8)
            nL.BackgroundTransparency = 1; nL.TextColor3 = C.text; nL.Font = Enum.Font.GothamBold; nL.TextSize = 12; nL.TextXAlignment = Enum.TextXAlignment.Left
            local dL = Instance.new("TextLabel", Card)
            dL.Text = desc or ""; dL.Size = UDim2.new(1,-80,0,12); dL.Position = UDim2.new(0,14,0,28)
            dL.BackgroundTransparency = 1; dL.TextColor3 = C.sub; dL.Font = Enum.Font.Gotham; dL.TextSize = 9; dL.TextXAlignment = Enum.TextXAlignment.Left

            local dropBtn = Instance.new("TextButton", Card)
            dropBtn.Size = UDim2.new(0,100,0,24); dropBtn.Position = UDim2.new(1,-106,0.5,-12)
            dropBtn.BackgroundColor3 = C.panel; dropBtn.BorderSizePixel = 0; dropBtn.Text = ""
            Instance.new("UICorner", dropBtn).CornerRadius = UDim.new(0,6)
            local dropLbl = Instance.new("TextLabel", dropBtn)
            dropLbl.Size = UDim2.new(1,-22,1,0); dropLbl.Position = UDim2.new(0,6,0,0)
            dropLbl.BackgroundTransparency = 1; dropLbl.TextColor3 = C.accent; dropLbl.Font = Enum.Font.GothamBold; dropLbl.TextSize = 10
            dropLbl.TextXAlignment = Enum.TextXAlignment.Left; dropLbl.TextTruncate = Enum.TextTruncate.AtEnd
            dropLbl.Text = cur and cur.text or "..."

            local listFrame = Instance.new("Frame", page)
            listFrame.Size = UDim2.new(1,-10,0,0); listFrame.BackgroundColor3 = C.card; listFrame.BorderSizePixel = 0; listFrame.Visible = false; listFrame.ClipsDescendants = true
            listFrame.LayoutOrder = cardOrder + 1
            order = cardOrder + 1
            Instance.new("UICorner", listFrame).CornerRadius = UDim.new(0,8)
            Instance.new("UIStroke", listFrame).Color = C.border
            local listScroll = Instance.new("ScrollingFrame", listFrame)
            listScroll.Size = UDim2.new(1,-4,1,-4); listScroll.Position = UDim2.new(0,2,0,2)
            listScroll.BackgroundTransparency = 1; listScroll.BorderSizePixel = 0; listScroll.ScrollBarThickness = 3; listScroll.ScrollBarImageColor3 = C.accent
            listScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
            local listLayout = Instance.new("UIListLayout", listScroll); listLayout.Padding = UDim.new(0,2); listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            local function refreshDropdownCanvas()
                local contentY = listLayout.AbsoluteContentSize.Y
                listScroll.CanvasSize = UDim2.new(0,0,0,math.max(contentY + 2, 0))
            end
            listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refreshDropdownCanvas)

            local function getSelectedIndices()
                local t = {}
                for i = 1, #list do if selected[i] then t[#t+1] = i end end
                return t
            end
            local function getSelectedValues()
                local t = {}
                for i = 1, #list do if selected[i] then t[#t+1] = list[i].value end end
                return t
            end
            local function getSelectedTexts()
                local t = {}
                for i = 1, #list do if selected[i] then t[#t+1] = list[i].text end end
                return t
            end
            local function updateDropLabel()
                if not isMulti then
                    dropLbl.Text = cur and cur.text or "..."
                    return
                end
                local labels = getSelectedTexts()
                if #labels == 0 then
                    dropLbl.Text = "None"
                elseif #labels == 1 then
                    dropLbl.Text = labels[1]
                else
                    dropLbl.Text = tostring(#labels) .. " selected"
                end
            end
            local function fireDropdownCb()
                if not cb then return end
                if isMulti then
                    cb(getSelectedIndices(), getSelectedValues(), getSelectedTexts())
                else
                    cb(cur and cur.text, cur and cur.value, curIdx)
                end
            end

            local function openList()
                local h = math.min(#list * 26 + 4, 150)
                listFrame.Size = UDim2.new(1,-10,0,h)
                for _, c in ipairs(listScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                for i, item in ipairs(list) do
                    local btn = Instance.new("TextButton", listScroll)
                    local isActive = isMulti and selected[i] or (i == curIdx)
                    btn.Size = UDim2.new(1,-4,0,24); btn.LayoutOrder = i; btn.BackgroundColor3 = isActive and Color3.fromRGB(0,40,80) or C.panel
                    btn.BorderSizePixel = 0; btn.Text = ""; btn.Font = Enum.Font.GothamBold; btn.TextSize = 10
                    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,4)
                    local lbl = Instance.new("TextLabel", btn)
                    lbl.Size = UDim2.new(1, isMulti and -28 or -8, 1,0); lbl.Position = UDim2.new(0,6,0,0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = C.text
                    lbl.Text = item.text; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.TextTruncate = Enum.TextTruncate.AtEnd
                    if isMulti then
                        local chk = Instance.new("Frame", btn)
                        chk.Size = UDim2.new(0,14,0,14); chk.Position = UDim2.new(1,-18,0.5,-7)
                        chk.BackgroundColor3 = selected[i] and C.accent or C.border; chk.BorderSizePixel = 0
                        Instance.new("UICorner", chk).CornerRadius = UDim.new(0,3)
                        local tick = Instance.new("TextLabel", chk)
                        tick.Size = UDim2.new(1,0,1,0); tick.BackgroundTransparency = 1
                        tick.Text = "✓"; tick.TextColor3 = Color3.fromRGB(255,255,255)
                        tick.Font = Enum.Font.GothamBold; tick.TextSize = 9; tick.Visible = selected[i]
                    end
                    btn.MouseButton1Click:Connect(function()
                        if isMulti then
                            selected[i] = not selected[i]
                            updateDropLabel()
                            fireDropdownCb()
                            openList()
                        else
                            curIdx = i; cur = list[i]; updateDropLabel(); listFrame.Visible = false
                            fireDropdownCb()
                        end
                    end)
                end
                refreshDropdownCanvas()
                listFrame.Visible = true
            end
            dropBtn.MouseButton1Click:Connect(function() listFrame.Visible = not listFrame.Visible; if listFrame.Visible then openList() end end)
            updateDropLabel()

            return {
                Set = function(v)
                    if isMulti then
                        for i = 1, #list do selected[i] = false end
                        for _, idx in ipairs(type(v) == "table" and v or {}) do if idx >= 1 and idx <= #list then selected[idx] = true end end
                    else
                        curIdx = math.clamp(tonumber(v) or 1, 1, math.max(1, #list)); cur = list[curIdx]
                    end
                    updateDropLabel()
                end,
                Get = function()
                    if isMulti then return getSelectedIndices(), getSelectedValues(), getSelectedTexts() end
                    return curIdx, cur and cur.value, cur and cur.text
                end
            }
        end

