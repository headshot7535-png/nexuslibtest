                opts = desc
                desc = ""
            end
            order = order + 1
            opts = opts or {}
            local minV    = opts.min     or 0
            local maxV    = opts.max     or 100
            local initV   = opts.default or minV
            local fmt     = opts.format  or function(v) return tostring(math.floor(v)) end

            local Card = Instance.new("Frame", page)
            Card.Size = UDim2.new(1,-10,0,60); Card.BackgroundColor3 = C.card
