            dL.BackgroundTransparency = 1; dL.TextColor3 = C.sub
            dL.Font = Enum.Font.Gotham; dL.TextSize = 9; dL.TextXAlignment = Enum.TextXAlignment.Left

            local Track = Instance.new("Frame",Card)
            Track.Size = UDim2.new(1,-28,0,6); Track.Position = UDim2.new(0,14,0,44)
            Track.BackgroundColor3 = C.panel; Track.BorderSizePixel = 0
            Instance.new("UICorner",Track).CornerRadius = UDim.new(1,0)

            local span = maxV - minV
            local pct0 = span > 0 and (initV - minV) / span or 0
            local Fill = Instance.new("Frame",Track)
            Fill.Size = UDim2.new(pct0,0,1,0); Fill.BackgroundColor3 = C.accent; Fill.BorderSizePixel = 0
            Instance.new("UICorner",Fill).CornerRadius = UDim.new(1,0)

            local Knob = Instance.new("TextButton",Track)
            Knob.Text = ""; Knob.Size = UDim2.new(0,16,0,16); Knob.AnchorPoint = Vector2.new(0.5,0.5)
            Knob.Position = UDim2.new(pct0,0,0.5,0)
            Knob.BackgroundColor3 = Color3.fromRGB(255,255,255); Knob.BorderSizePixel = 0; Knob.ZIndex = 4
            Instance.new("UICorner",Knob).CornerRadius = UDim.new(1,0)

            local curVal = initV
            local dragging = false
            local function isPressStart(i)
                return i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch
            end
            local function isPressEnd(i)
                return i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch
            end
            local function apply(ix)
                if Track.AbsoluteSize.X <= 0 then return end
                local rel = math.clamp(ix - Track.AbsolutePosition.X, 0, Track.AbsoluteSize.X)
                local p   = rel / Track.AbsoluteSize.X
                local v   = minV + math.round((maxV - minV) * p)
                curVal = v
                Fill.Size = UDim2.new(p,0,1,0); Knob.Position = UDim2.new(p,0,0.5,0)
                vL.Text = fmt(v)
                if cb then cb(v) end
            end
            Knob.InputBegan:Connect(function(i)
                if isPressStart(i) then dragging = true end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if not dragging then return end
                if i.UserInputType == Enum.UserInputType.MouseMovement
                    or i.UserInputType == Enum.UserInputType.Touch then
                    apply(i.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if isPressEnd(i) then dragging = false end
            end)
            Track.InputBegan:Connect(function(i)
                if isPressStart(i) then apply(i.Position.X) end
            end)

            local function setFromValue(rawV, silent)
                local v = math.round(math.clamp(rawV, minV, maxV))
                curVal = v
                local s = maxV - minV
                local p = s > 0 and (v - minV) / s or 0
                Fill.Size = UDim2.new(p, 0, 1, 0)
                Knob.Position = UDim2.new(p, 0, 0.5, 0)
                vL.Text = fmt(v)
                if not silent and cb then cb(v) end
            end

            return { Get = function() return curVal end, Set = setFromValue }
        end

