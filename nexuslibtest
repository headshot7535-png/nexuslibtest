-- ── HTTP helper (executor-agnostic) ───────────────────────────
local function httpRequest(opts)
    local fn = (syn and syn.request)
             or (http and http.request)
             or (http_request)
             or (request)
             or (HttpPost and function(o)
                 return { Body = HttpPost(o.Url, o.Body or "", o.Headers and o.Headers["Content-Type"] or "application/json") }
             end)
    if not fn then return nil end
    return fn(opts)
end

-- Clipboard text (executors). Raw image paste like Discord desktop is not available in Roblox; use image **links**.
local function getClipboardText()
    local s = nil
    if type(getclipboard) == "function" then
        pcall(function() s = getclipboard() end)
    elseif type(readclipboard) == "function" then
        pcall(function() s = readclipboard() end)
    end
    if type(s) ~= "string" then return nil end
    s = s:match("^%s*(.-)%s*$")
    if s == "" then return nil end
    return s
end

local function isImageLikeUrl(s)
    if type(s) ~= "string" then return false end
    s = s:match("^%s*(.-)%s*$") or ""
    local low = s:lower()
    if low:match("^rbxassetid://%d+") or low:match("^rbxthumb://") then return true end
    if not low:match("^https?://") then return false end
    if low:match("%.png") or low:match("%.jpe?g") or low:match("%.gif") or low:match("%.webp") or low:match("%.avif") then
        return true
    end
    if low:find("discordapp.com/attachments", 1, true) or low:find("discord.com/attachments", 1, true) then return true end
    if low:find("i.imgur.com", 1, true) or low:find("imgur.com", 1, true) then return true end
    if low:find("media.discordapp.net", 1, true) then return true end
    if low:find("gyazo.com", 1, true) or low:find("prnt.sc", 1, true) then return true end
    return false
end

